# Set after deploying the contract (see contracts/.env.example)
CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS

# RPC endpoint — local Anvil by default
RPC_URL=http://localhost:8545

PORT=3000

# Dev-only: private keys for testing the API manually with curl.
# In production agents bring their own keys and sign client-side.
# For local Anvil: use any of the pre-funded accounts printed when you run `anvil`
REQUESTER_PRIVATE_KEY=0x_YOUR_REQUESTER_PRIVATE_KEY
WORKER_PRIVATE_KEY=0x_YOUR_WORKER_PRIVATE_KEY

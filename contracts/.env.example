# Deployer / owner private key
# For local Anvil: use any of the pre-funded accounts printed when you run `anvil`
# For Base Sepolia: a funded wallet (get gas from https://www.alchemy.com/faucets/base-sepolia)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY

# RPC endpoint
# Local Anvil:  http://localhost:8545
# Base Sepolia: https://sepolia.base.org  (free public endpoint, no key required)
# Base Mainnet: https://mainnet.base.org
RPC_URL=http://localhost:8545

# Set after deploying — printed by `forge script script/Deploy.s.sol --broadcast`
CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS

# Etherscan-compatible block explorer API key for contract verification (optional)
# Base Sepolia / Mainnet explorer: https://basescan.org
ETHERSCAN_API_KEY=YOUR_BASESCAN_API_KEY
